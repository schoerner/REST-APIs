# Vollständige öffentliche URL des Servers (muss mit der Cloudflare-Tunnel-URL übereinstimmen)
# Beispiel: https://api.meine-schule.de
DOMAIN=https://api.example.com

# Interner Port des Servers (Standard: 8000, nur ändern wenn nötig)
PORT=8000

# Optionales Passwort für den Admin-Reset-Endpunkt
# Leer lassen, um den Endpunkt zu deaktivieren
RESET_PASSWORD=

# Cloudflare Tunnel Token (aus dem Zero Trust Dashboard kopieren)
CLOUDFLARE_TUNNEL_TOKEN=
